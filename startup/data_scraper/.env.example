# API Keys for LLM backends
# Copy this file to .env and add your actual API keys

# Gemini API Key (recommended - fast and affordable)
# Get it from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Alternative: Google API Key (also works for Gemini)
# GOOGLE_API_KEY=your-google-api-key-here

# OpenAI API Key (more expensive alternative)
# Get it from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your-openai-api-key-here

# Ollama settings (for local LLM - no API key needed)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_AUTH=optional-auth-token-if-needed

